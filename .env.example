# Environment — copy to .env.local and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (Google OAuth enabled in Clerk Dashboard → Social Connections)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# PostgreSQL (Supabase, Neon, or Vercel Postgres)
DATABASE_URL=postgresql://user:password@host:5432/legacy_in_motion

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — create products in Stripe Dashboard, paste price IDs here
STRIPE_PRICE_HLV_REPORT=price_...
STRIPE_PRICE_LEGACY_VAULT=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...
STRIPE_PRICE_PREMIUM_HYBRID=price_...

# Phase 2
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# ENCRYPTION_KEY=  # 32-byte hex for AES-256 field encryption
